---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'A dead-simple headless CMS built for developers and AI. Fork it, own it forever. Runs 100% free on Cloudflare.', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --c-bg: #ffffff;
        --c-bg-alt: #f8f9fa;
        --c-border: #e5e7eb;
        --c-text: #111827;
        --c-text-muted: #6b7280;
        --c-primary: #111827;
        --c-accent: #2563eb;
        --c-accent-light: #dbeafe;
        --c-code-bg: #1e293b;
        --max-w: 72rem;
        --max-w-prose: 48rem;
      }

      html {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        color: var(--c-text);
        background: var(--c-bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        scroll-behavior: smooth;
      }

      body { min-height: 100dvh; display: flex; flex-direction: column; }

      a { color: var(--c-accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      code, pre { font-family: 'JetBrains Mono', monospace; }

      pre {
        background: var(--c-code-bg);
        color: #e2e8f0;
        padding: 1.25rem 1.5rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        font-size: 0.875rem;
        line-height: 1.7;
      }

      code:not(pre code) {
        background: var(--c-bg-alt);
        border: 1px solid var(--c-border);
        padding: 0.15rem 0.4rem;
        border-radius: 0.25rem;
        font-size: 0.875em;
      }

      .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }
      .prose { max-width: var(--max-w-prose); }
      .prose h1 { font-size: 2.25rem; font-weight: 700; line-height: 1.2; margin-bottom: 1rem; }
      .prose h2 { font-size: 1.5rem; font-weight: 600; line-height: 1.3; margin-top: 2.5rem; margin-bottom: 0.75rem; }
      .prose h3 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; }
      .prose p { margin-bottom: 1rem; color: var(--c-text-muted); }
      .prose ul, .prose ol { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--c-text-muted); }
      .prose li { margin-bottom: 0.25rem; }
      .prose pre { margin-bottom: 1.5rem; }
      .prose table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.875rem; }
      .prose th, .prose td { padding: 0.625rem 1rem; text-align: left; border-bottom: 1px solid var(--c-border); }
      .prose th { font-weight: 600; color: var(--c-text); background: var(--c-bg-alt); }
      .prose td { color: var(--c-text-muted); }
      .prose strong { color: var(--c-text); }
    </style>
  </head>
  <body>
    <!-- Header -->
    <header style="border-bottom: 1px solid var(--c-border); position: sticky; top: 0; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); z-index: 50;">
      <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 4rem;">
        <a href="/" style="font-size: 1.25rem; font-weight: 700; color: var(--c-text); text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
          Cloudcore
        </a>
        <nav style="display: flex; align-items: center; gap: 2rem; font-size: 0.9375rem;">
          <a href="/docs/getting-started" style="color: var(--c-text-muted);">Docs</a>
          <a href="/docs/api" style="color: var(--c-text-muted);">API</a>
          <a href="/docs/security" style="color: var(--c-text-muted);">Security</a>
          <a href="/docs/deployment" style="color: var(--c-text-muted);">Deploy</a>
          <a href="https://github.com/cloudcore-cms" style="color: var(--c-text-muted);" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </div>
    </header>

    <main style="flex: 1;">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="border-top: 1px solid var(--c-border); margin-top: 4rem;">
      <div class="container" style="padding-top: 3rem; padding-bottom: 3rem;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr)); gap: 2rem; font-size: 0.875rem;">
          <div>
            <p style="font-weight: 600; margin-bottom: 0.75rem; color: var(--c-text);">Cloudcore CMS</p>
            <p style="color: var(--c-text-muted); line-height: 1.5;">Lightweight headless CMS on Cloudflare Workers. Open source, edge-deployed, secure by default.</p>
          </div>
          <div>
            <p style="font-weight: 600; margin-bottom: 0.75rem; color: var(--c-text);">Docs</p>
            <ul style="list-style: none; color: var(--c-text-muted); line-height: 2;">
              <li><a href="/docs/getting-started">Getting Started</a></li>
              <li><a href="/docs/api">API Reference</a></li>
              <li><a href="/docs/blocks">Block Types</a></li>
              <li><a href="/docs/security">Security</a></li>
            </ul>
          </div>
          <div>
            <p style="font-weight: 600; margin-bottom: 0.75rem; color: var(--c-text);">Deploy</p>
            <ul style="list-style: none; color: var(--c-text-muted); line-height: 2;">
              <li><a href="/docs/deployment">Deployment Guide</a></li>
              <li><a href="/docs/public-api">Public API</a></li>
              <li><a href="/docs/frontends">Frontend Starters</a></li>
              <li><a href="/docs/environment">Environment Variables</a></li>
            </ul>
          </div>
          <div>
            <p style="font-weight: 600; margin-bottom: 0.75rem; color: var(--c-text);">Repositories</p>
            <ul style="list-style: none; color: var(--c-text-muted); line-height: 2;">
              <li><a href="https://github.com/cloudcore-cms/cloudcore-cms" target="_blank" rel="noopener">CMS (API + Admin)</a></li>
              <li><a href="https://github.com/cloudcore-cms/cloudcore-api" target="_blank" rel="noopener">Public API (Read-Only)</a></li>
              <li><a href="https://github.com/cloudcore-cms/cloudcore-next" target="_blank" rel="noopener">Next.js Starter</a></li>
              <li><a href="https://github.com/cloudcore-cms/cloudcore-react" target="_blank" rel="noopener">React Starter</a></li>
              <li><a href="https://github.com/cloudcore-cms/cloudcore-astro" target="_blank" rel="noopener">Astro Starter</a></li>
            </ul>
          </div>
        </div>
        <p style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--c-border); color: var(--c-text-muted); font-size: 0.8125rem; text-align: center;">
          MIT License &middot; Built with Cloudflare Workers, Hono, D1, R2
        </p>
      </div>
    </footer>
  </body>
</html>
