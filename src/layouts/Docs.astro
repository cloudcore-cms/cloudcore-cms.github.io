---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;

const sections = [
  {
    title: 'Getting Started',
    items: [
      { href: '/docs/getting-started', label: 'Quick Start' },
      { href: '/docs/architecture', label: 'Architecture' },
    ],
  },
  {
    title: 'Content',
    items: [
      { href: '/docs/blocks', label: 'Block Types' },
      { href: '/docs/api', label: 'API Reference' },
    ],
  },
  {
    title: 'Authentication',
    items: [
      { href: '/docs/authentication', label: 'Auth Methods' },
      { href: '/docs/security', label: 'Security' },
    ],
  },
  {
    title: 'Extend',
    items: [
      { href: '/docs/ecom', label: 'E-commerce' },
      { href: '/docs/mcp', label: 'MCP Server' },
    ],
  },
  {
    title: 'Deployment',
    items: [
      { href: '/docs/deployment', label: 'Deploy CMS' },
      { href: '/docs/public-api', label: 'Public API' },
      { href: '/docs/frontends', label: 'Frontend Starters' },
      { href: '/docs/environment', label: 'Environment Variables' },
    ],
  },
];
---

<Base title={`${title} - Cloudcore Docs`} description={description}>
  <div class="docs-layout container">
    <!-- Mobile sidebar toggle -->
    <input type="checkbox" id="sidebar-toggle" class="sidebar-toggle" />
    <label for="sidebar-toggle" class="sidebar-toggle-label">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="margin-right: 0.375rem;">
        <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Navigation
    </label>

    <!-- Sidebar -->
    <aside class="docs-sidebar">
      <nav style="font-size: 0.875rem;">
        {sections.map((section) => (
          <div style="margin-bottom: 1.5rem;">
            <p style="font-weight: 600; color: var(--c-text); margin-bottom: 0.5rem; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.05em;">
              {section.title}
            </p>
            <ul style="list-style: none;">
              {section.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    style={`display: block; padding: 0.375rem 0.75rem; border-radius: 0.375rem; margin-bottom: 0.125rem; color: ${currentPath === item.href || currentPath === item.href + '/' ? 'var(--c-accent)' : 'var(--c-text-muted)'}; background: ${currentPath === item.href || currentPath === item.href + '/' ? 'var(--c-accent-light)' : 'transparent'}; font-weight: ${currentPath === item.href || currentPath === item.href + '/' ? '500' : '400'}; text-decoration: none;`}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- Content -->
    <article class="prose docs-content">
      <slot />
    </article>
  </div>

  <style>
    .docs-layout {
      display: flex;
      gap: 3rem;
      padding-top: 2rem;
      padding-bottom: 4rem;
    }

    .docs-sidebar {
      width: 14rem;
      flex-shrink: 0;
      position: sticky;
      top: 5.5rem;
      align-self: flex-start;
      max-height: calc(100dvh - 7rem);
      overflow-y: auto;
    }

    .docs-content {
      flex: 1;
      min-width: 0;
    }

    .sidebar-toggle { display: none; }
    .sidebar-toggle-label { display: none; }

    @media (max-width: 48rem) {
      .docs-layout {
        flex-direction: column;
        gap: 0;
      }

      .sidebar-toggle-label {
        display: flex;
        align-items: center;
        padding: 0.75rem 0;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--c-text-muted);
        cursor: pointer;
        border-bottom: 1px solid var(--c-border);
        margin-bottom: 1.5rem;
      }

      .docs-sidebar {
        display: none;
        width: 100%;
        position: static;
        max-height: none;
        padding-bottom: 1rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--c-border);
      }

      .sidebar-toggle:checked ~ .docs-sidebar {
        display: block;
      }

      .sidebar-toggle:checked ~ .sidebar-toggle-label {
        margin-bottom: 0.5rem;
      }
    }
  </style>
</Base>
